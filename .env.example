# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
HISTORY_ALLOWED_OPEN_IDS=ou_xxx
HISTORY_SESSION_SECRET=replace_with_long_random_secret
HISTORY_SESSION_TTL_SEC=604800
HISTORY_COOKIE_NAME=feicodex_history_session
FEISHU_OAUTH_AUTHORIZE_URL=https://accounts.feishu.cn/open-apis/authen/v1/authorize
FEISHU_OAUTH_TOKEN_URL=https://open.feishu.cn/open-apis/authen/v1/access_token
FEISHU_OAUTH_USERINFO_URL=https://open.feishu.cn/open-apis/authen/v1/user_info

# Required for API auth between long_conn and app.py
BRIDGE_API_TOKEN=replace_with_long_random_token

# API location and route prefix
BRIDGE_API_PREFIX=/appbridge/api
BRIDGE_CONTROL_BASE=http://127.0.0.1:18788

# Runtime file locations (relative to project dir when using provided scripts)
BRIDGE_UPLOAD_ROOT=./data/uploads
BRIDGE_STATE_PATH=./data/state.json
BRIDGE_HISTORY_PATH=./data/history.json
BRIDGE_HISTORY_DB_PATH=./data/history.db
BRIDGE_HISTORY_MAX_TURNS=2000
BRIDGE_USER_CHAT_MAP_PATH=./data/user_chat_map.json
BRIDGE_AUTH_PROFILES_DIR=./data/auth_profiles
BRIDGE_AUTH_HOMES_DIR=./data/auth_homes
BRIDGE_AUTH_REGISTRY_PATH=./data/auth_profiles_registry.json

# Menu event_key -> action mapping (JSON object)
# Recommended menu entries in Feishu:
# - menu_project_manage
# - menu_session_manage
BRIDGE_MENU_ACTIONS_JSON={"menu_project_manage":"open_project_manage","menu_session_manage":"open_session_manage"}

# Project registry for project-management card (JSON object)
BRIDGE_PROJECTS_JSON={"bridge":"."}
BRIDGE_PROJECT_ROOT=./projects
BRIDGE_PROJECTS_STORE_PATH=./data/projects.json

# Runtime defaults
BRIDGE_DEFAULT_CWD=.
BRIDGE_DEFAULT_MODEL=gpt-5.3-codex
BRIDGE_DEFAULT_SANDBOX=danger-full-access
BRIDGE_DEFAULT_APPROVAL_POLICY=never
BRIDGE_DEFAULT_PERSONALITY=pragmatic
BRIDGE_TURN_TIMEOUT_SEC=21600
BRIDGE_PROGRESS_PING_INTERVAL_SEC=180
BRIDGE_STREAMING_CARD_UPDATE_INTERVAL_SEC=5
BRIDGE_IDLE_EVICT_SEC=600
BRIDGE_IDLE_SWEEP_INTERVAL_SEC=60
BRIDGE_AUTO_AUTH_SWITCH_ENABLED=true
BRIDGE_AUTO_AUTH_SWITCH_THRESHOLD_PCT=100
BRIDGE_STREAMING_CARD_ENABLED=true
BRIDGE_TYPING_REACTION_ENABLED=true
BRIDGE_SINGLE_CHAT_ONLY=true
BRIDGE_CARD_AUTO_DELETE_ON_ACTION=true
BRIDGE_OUTPUT_FILE_AUTO_SEND=false
# 0 means unlimited count (subject to Feishu API frequency control)
BRIDGE_OUTPUT_FILE_MAX_COUNT=0
# Feishu /im/v1/files upload limit is 30MB per file
BRIDGE_OUTPUT_FILE_MAX_SIZE_MB=30
BRIDGE_OUTPUT_FILE_MAX_AGE_SEC=3600
BRIDGE_MCP_SERVER_NAME=feishu-bridge-files
# BRIDGE_MCP_FILE_ALLOWED_DIRS=/root/bridgespace/projects
# BRIDGE_MCP_FILE_MAX_SIZE_MB=30

# Log level for long_conn.py: DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO

# Optional: set if your network requires outbound proxy for Codex/OpenAI access.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5h://127.0.0.1:7891
# NO_PROXY=localhost,127.0.0.1,::1
