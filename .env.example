# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Required for API auth between long_conn and app.py
BRIDGE_API_TOKEN=replace_with_long_random_token

# API location and route prefix
BRIDGE_API_PREFIX=/appbridge/api
BRIDGE_CONTROL_BASE=http://127.0.0.1:18788

# Runtime file locations (relative to project dir when using provided scripts)
BRIDGE_UPLOAD_ROOT=./data/uploads
BRIDGE_STATE_PATH=./data/state.json

# Menu event_key -> action mapping (JSON object)
# Recommended menu entries in Feishu:
# - menu_project_manage
# - menu_session_manage
BRIDGE_MENU_ACTIONS_JSON={"menu_project_manage":"open_project_manage","menu_session_manage":"open_session_manage"}

# Project registry for project-management card (JSON object)
BRIDGE_PROJECTS_JSON={"bridge":"."}

# Runtime defaults
BRIDGE_DEFAULT_CWD=.
BRIDGE_DEFAULT_MODEL=gpt-5.3-codex
BRIDGE_DEFAULT_SANDBOX=danger-full-access
BRIDGE_DEFAULT_APPROVAL_POLICY=never
BRIDGE_DEFAULT_PERSONALITY=pragmatic
BRIDGE_TURN_TIMEOUT_SEC=21600
BRIDGE_PROGRESS_PING_INTERVAL_SEC=180
BRIDGE_SINGLE_CHAT_ONLY=true

# Log level for long_conn.py: DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO

# Optional: set if your network requires outbound proxy for Codex/OpenAI access.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5h://127.0.0.1:7891
# NO_PROXY=localhost,127.0.0.1,::1
